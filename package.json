{
  "name": "@velkinvv/plainerv",
  "version": "0.1.2",
  "description": "Современная библиотека UI компонентов с поддержкой темизации и TypeScript",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.cjs.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.esm.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles": "./dist/styles.css",
    "./fonts/*": "./dist/styles/fonts/*"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "clean": "npx --yes rimraf dist",
    "start": "PUBLIC_URL=/plainerv npm run dev",
    "build": "npm run clean && cross-env NODE_ENV=production rollup -c rollup.config.mjs && node ./scripts/verify-package.mjs",
    "build:dev": "npm run clean && cross-env NODE_ENV=development rollup -c rollup.config.mjs && node ./scripts/verify-package.mjs",
    "dev": "rollup -c rollup.config.mjs --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.{ts,tsx}\" --fix --cache",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.{ts,tsx}\" --cache",
    "lint:fix-all": "eslint \"{src,apps,libs,test}/**/*.{ts,tsx}\" --fix --cache --max-warnings 0",
    "lint:staged": "lint-staged",
    "fix-all": "npm run format && npm run lint:fix-all",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "prestorybook": "npx --yes rimraf \"src/components/ui/table_pkg\"",
    "storybook": "storybook dev -p 6006",
    "prebuild-storybook": "npx --yes rimraf \"src/components/ui/table_pkg\"",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:check": "jest --coverage --coverageThreshold='{\"global\":{\"branches\":60,\"functions\":60,\"lines\":60,\"statements\":60}}'",
    "analyze": "npm run build && echo Bundle analysis saved to dist/stats.html",
    "quality:check": "npm run type-check && npm run lint:check && npm run format:check",
    "quality:fix": "npm run fix-all && npm run type-check",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "publish:npm": "npm run build && npm publish"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "typescript",
    "theme",
    "styled-components",
    "design-system",
    "ui-kit",
    "component-library",
    "react-components",
    "frontend",
    "ui-components",
    "typescript-components"
  ],
  "author": "VelkinVV <velkinvv@mail.ru>",
  "license": "MIT",
  "homepage": "https://github.com/velkinvv/PlainerV-ui-kit#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/velkinvv/PlainerV-ui-kit.git"
  },
  "bugs": {
    "url": "https://github.com/velkinvv/PlainerV-ui-kit/issues"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "dayjs": "^1.11.13",
    "framer-motion": "^11.0.0",
    "react-hook-form": "^7.48.0",
    "styled-components": "^6.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rollup/rollup-linux-x64-gnu": "^4.54.0",
    "@storybook/addon-docs": "^9.1.5",
    "@storybook/addon-links": "^9.1.5",
    "@storybook/addon-themes": "^9.1.5",
    "@storybook/csf-plugin": "^9.1.5",
    "@storybook/react-vite": "^9.1.5",
    "@storybook/test": "^9.0.0-alpha.2",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/styled-components": "^5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-storybook": "9.1.5",
    "eslint-plugin-unused-imports": "^4.2.0",
    "husky": "^9.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.6.2",
    "rollup": "^4.54.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "storybook": "^9.1.5",
    "ts-jest": "^29.1.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --cache",
      "prettier --write"
    ],
    "*.{js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
